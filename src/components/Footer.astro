---
import Section from "./Section.astro";
import Logo from "./Logo.astro";
import { navigation, site, legal } from "../data/site";
import { buildStamp } from "../lib/farm";

const year = new Date().getFullYear();
---

<Section class="pt-11 pb-6 px-5 lg:pt-[6.5rem] lg:px-7.5 lg:pb-12 xl:px-10" crosses customPaddings>
  <div
    class="flex items-center justify-center h-[6.5rem] mb-6 border-b border-n-6 lg:justify-start"
  >
    <Logo />
    <nav aria-label="Footer" class="hidden lg:flex items-center justify-center ml-auto">
      {
        navigation
          .filter((item) => !item.onlyMobile)
          .map((item) => (
            <a
              class="px-12 py-8 font-code text-xs font-semibold leading-5 uppercase text-n-1/50 transition-colors hover:text-n-1"
              href={item.url}
            >
              {item.title}
            </a>
          ))
      }
    </nav>
  </div>
  <div class="lg:flex lg:items-center lg:justify-between">
    <div class="caption text-n-4 mb-6 text-center lg:mb-0 lg:text-left">
      <div>© {year} {legal.name} (UEN {legal.uen})</div>
      <div class="mt-1 text-n-4/70">{legal.address}</div>
      <div class="mt-1 text-n-4/70">
        Built by the farm · {buildStamp()} ·
        <a class="transition-colors hover:text-n-1" href="/privacy">Privacy</a>
      </div>
    </div>
    <div class="flex justify-center gap-8">
      <a
        class="flex items-center justify-center w-10 h-10 bg-n-7 rounded-full text-n-2 transition-colors hover:bg-n-6 hover:text-brand-magenta"
        href={site.github}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>
      <a
        class="flex items-center justify-center w-10 h-10 bg-n-7 rounded-full text-n-2 transition-colors hover:bg-n-6 hover:text-brand-magenta"
        href="/connect"
        aria-label="Connect"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
      </a>
    </div>
  </div>
</Section>
