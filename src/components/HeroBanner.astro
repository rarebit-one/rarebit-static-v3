---
// Framed cinematic image band — reuses the home hero's conic-gradient frame so
// brand shots (torii / operator / factory) can headline secondary pages and
// break up the otherwise-identical centered-heading openers. A top scrim keeps
// the section's crosses/heading legible where the banner meets the page.
interface Props {
  src: string;
  alt?: string;
  class?: string;
  /** Aspect of the framed image; default a wide cinematic band. */
  aspect?: string;
  width?: number;
  height?: number;
}
const {
  src,
  alt = "",
  class: className = "",
  aspect = "aspect-[16/6]",
  width = 1536,
  height = 1024,
} = Astro.props;
---

<div class={`reveal relative z-1 p-0.5 rounded-2xl bg-conic-gradient ${className}`}>
  <div class={`relative overflow-hidden rounded-[0.875rem] bg-n-8 ${aspect}`}>
    <img
      class="w-full h-full object-cover"
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-n-8/50 via-transparent to-n-8/10"></div>
  </div>
</div>
