---
// No-JS accordion (native <details>/<summary>), styled to the Brainwave card
// chrome — the template's FAQ layout without shipping a framework. Pass an
// array of { q, a }. One item open by default (the first).
import Tagline from "./Tagline.astro";

interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  tag?: string;
  title?: string;
  items: FaqItem[];
  class?: string;
}
const { tag, title, items, class: className = "" } = Astro.props;
---

<div class={`max-w-[48rem] mx-auto ${className}`}>
  {tag && <Tagline class="mb-4 md:justify-center">{tag}</Tagline>}
  {title && <h2 class="h3 mb-8 text-center md:mb-12">{title}</h2>}

  <div class="flex flex-col gap-3">
    {
      items.map((item, index) => (
        <details
          class="reveal group rounded-2xl border border-n-1/10 bg-n-7 transition-colors open:border-brand-cyan/30 hover:border-n-1/20"
          open={index === 0}
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 list-none px-5 py-4 md:px-7 md:py-5">
            <span class="h6 text-n-1">{item.q}</span>
            <span class="relative flex h-6 w-6 shrink-0 items-center justify-center text-n-4 transition-colors group-open:text-brand-cyan">
              <span class="absolute h-0.5 w-3.5 bg-current" />
              <span class="absolute h-3.5 w-0.5 bg-current transition-transform group-open:rotate-90 group-open:scale-y-0" />
            </span>
          </summary>
          <p class="body-2 px-5 pb-5 -mt-1 text-n-4 md:px-7 md:pb-6">{item.a}</p>
        </details>
      ))
    }
  </div>
</div>
