---
import Tagline from "./Tagline.astro";

interface Props {
  class?: string;
  textAlignClass?: string;
  tag?: string;
  title?: string;
  text?: string;
}

const {
  class: className = "",
  textAlignClass = "md:text-center",
  tag,
  title,
  text,
} = Astro.props;
---

{/* Pass class="reveal" at below-fold call sites for the scroll-driven
    entrance — not defaulted here, since above-the-fold headings can flash
    on some engines before the view() timeline resolves. */}
<div class={`max-w-[50rem] mx-auto mb-12 ${textAlignClass} lg:mb-20 ${className}`}>
  {tag && <Tagline class="mb-4 md:justify-center">{tag}</Tagline>}
  {title && <h2 class="h2">{title}</h2>}
  {text && <p class="body-2 mt-4 text-n-4">{text}</p>}
  <slot />
</div>
