---
import Section from "../Section.astro";
import Heading from "../Heading.astro";
import { benefits } from "../../data/site";
---

<Section id="automations" class="overflow-hidden">
  <div class="container relative z-2">
    <Heading
      class="md:max-w-md lg:max-w-2xl"
      title="Workflows that run themselves"
      text="The automations on our own farm — the same ones we bring to every AI adoption engagement."
    />

    {/* Scroll-snap carousel — the CSS stand-in for the template's Splide.
        Bleeds past the container on mobile (both edges) and to the right
        viewport edge on md+, like the template's splide-visible overflow. */}
    <div
      class="flex gap-6 overflow-x-auto overflow-y-hidden snap-x snap-mandatory no-scrollbar -ml-5 pl-5 -mr-5 pr-5 scroll-px-5 md:ml-0 md:pl-0 md:mr-[calc(50%-50vw)] md:pr-0 md:scroll-px-0 md:cursor-grab"
      data-benefits-track
    >
      {
        benefits.map((item) => (
          <div
            class="block relative shrink-0 snap-start w-full max-w-[24rem] p-0.5 bg-no-repeat bg-[length:100%_100%]"
            style={`background-image: url(${item.backgroundUrl})`}
          >
            <div class="relative z-2 flex flex-col h-[22.625rem] p-6 md:p-[2.375rem] pointer-events-none">
              <h5 class="h5 mb-5">{item.title}</h5>
              <p class="body-2 mb-6 text-n-3">{item.text}</p>
              <div class="flex items-center mt-auto">
                <img src={item.iconUrl} width="48" height="48" alt="" />
                <div class="ml-auto font-code text-xs font-bold text-n-1 uppercase tracking-wider">
                  Always on
                </div>
                <svg class="ml-5 fill-n-1" width="24" height="24">
                  <path d="M8.293 5.293a1 1 0 0 1 1.414 0l6 6a1 1 0 0 1 0 1.414l-6 6a1 1 0 0 1-1.414-1.414L13.586 12 8.293 6.707a1 1 0 0 1 0-1.414z" />
                </svg>
              </div>
            </div>

            {item.light && (
              <div class="absolute top-0 left-1/4 w-full aspect-square bg-radial from-[#28206C] to-[#28206C]/0 to-70% pointer-events-none" />
            )}

            <div class="absolute inset-0.5 bg-n-8" style="clip-path: url(#benefits)">
              <div class="absolute inset-0 opacity-0 transition-opacity hover:opacity-10">
                <img
                  class="w-full h-full object-cover"
                  src={item.imageUrl}
                  width="380"
                  height="362"
                  alt=""
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex mt-12 -mx-2 md:mt-15 lg:justify-center xl:mt-20">
      {
        benefits.map((item, index) => (
          <button
            class="relative w-6 h-6 mx-2 cursor-pointer"
            data-benefits-dot
            aria-label={`Go to ${item.title}`}
            aria-current={index === 0 ? "true" : "false"}
          >
            <span
              class={`absolute inset-0 bg-conic-gradient rounded-full transition-opacity ${
                index === 0 ? "opacity-100" : "opacity-0"
              }`}
            />
            <span class="absolute inset-0.25 bg-n-8 rounded-full">
              <span class="absolute inset-2 bg-n-1 rounded-full" />
            </span>
          </button>
        ))
      }
    </div>

    <svg class="block" width="0" height="0">
      <clipPath id="benefits" clipPathUnits="objectBoundingBox">
        <path
          d="M0.079,0 h0.756 a0.079,0.083,0,0,1,0.058,0.026 l0.086,0.096 A0.079,0.083,0,0,1,1,0.179 V0.917 c0,0.046,-0.035,0.083,-0.079,0.083 H0.079 c-0.044,0,-0.079,-0.037,-0.079,-0.083 V0.083 C0,0.037,0.035,0,0.079,0"
        ></path>
      </clipPath>
    </svg>
  </div>
</Section>

<script>
  const track = document.querySelector<HTMLElement>("[data-benefits-track]");
  const slides = Array.from(track?.children ?? []) as HTMLElement[];
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-benefits-dot]"));
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (track && slides.length > 0) {
    // offsetLeft is measured from the offsetParent (the container), not the
    // track's scroll origin — subtract the first slide's offset so positions
    // are comparable with scrollLeft.
    const slideLeft = (index: number) => slides[index].offsetLeft - slides[0].offsetLeft;

    const setActive = (active: number) => {
      dots.forEach((dot, index) => {
        const isActive = index === active;
        dot.setAttribute("aria-current", isActive ? "true" : "false");
        dot.firstElementChild?.classList.toggle("opacity-100", isActive);
        dot.firstElementChild?.classList.toggle("opacity-0", !isActive);
      });
    };

    const nearestSlide = () =>
      slides.reduce(
        (best, _slide, index) =>
          Math.abs(slideLeft(index) - track.scrollLeft) <
          Math.abs(slideLeft(best) - track.scrollLeft)
            ? index
            : best,
        0
      );

    // The furthest snap position the track can actually rest on — slides
    // near the end can't be left-aligned once the remaining content is
    // narrower than the viewport.
    const clampToSnap = (left: number) => {
      const max = track.scrollWidth - track.clientWidth;
      return slides.reduce(
        (best, _slide, index) =>
          slideLeft(index) <= Math.min(left, max) ? slideLeft(index) : best,
        0
      );
    };

    // Programmatic glides suspend snapping: Chromium cancels smooth
    // scrollTo() on a mandatory-snap container, so snap is turned off for
    // the animation and restored once scroll events go quiet. Targets are
    // pre-clamped to a real snap position so the restore never yanks the
    // track. While a glide runs the scroll handler must not recompute the
    // active dot (a clamped end-target would override the user's choice).
    let gliding = false;
    let glideSettleTimer = 0;

    const armGlideSettle = () => {
      clearTimeout(glideSettleTimer);
      glideSettleTimer = window.setTimeout(() => {
        gliding = false;
        track.style.scrollSnapType = "";
      }, 200);
    };

    const glideTo = (left: number) => {
      gliding = true;
      track.style.scrollSnapType = "none";
      track.scrollTo({
        left,
        behavior: reduceMotion.matches ? "auto" : "smooth",
      });
      armGlideSettle();
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        setActive(index);
        // Scroll the track directly (not scrollIntoView) so the page never
        // moves vertically when a dot is tapped.
        glideTo(clampToSnap(slideLeft(index)));
      });
    });

    let raf = 0;
    track.addEventListener(
      "scroll",
      () => {
        if (gliding) {
          armGlideSettle();
          return;
        }
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => setActive(nearestSlide()));
      },
      { passive: true }
    );

    // Mouse drag-to-scroll (Splide-style). Touch devices scroll natively;
    // snap is suspended while the track follows the pointer, then restored
    // with a glide to the nearest slide.
    let dragging = false;
    let dragStartX = 0;
    let dragStartScroll = 0;

    track.addEventListener("pointerdown", (event) => {
      if (event.pointerType !== "mouse" || event.button !== 0) return;
      dragging = true;
      dragStartX = event.clientX;
      dragStartScroll = track.scrollLeft;
      track.style.scrollSnapType = "none";
      track.style.cursor = "grabbing";
    });

    window.addEventListener("pointermove", (event) => {
      if (!dragging) return;
      track.scrollLeft = dragStartScroll - (event.clientX - dragStartX);
    });

    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      track.style.cursor = "";
      const nearest = nearestSlide();
      setActive(nearest);
      glideTo(clampToSnap(slideLeft(nearest)));
    };
    window.addEventListener("pointerup", endDrag);
    window.addEventListener("pointercancel", endDrag);

    // Keep native image drag from hijacking the gesture.
    track.addEventListener("dragstart", (event) => event.preventDefault());
  }
</script>
