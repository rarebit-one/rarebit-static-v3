---
import Section from "../Section.astro";
import Heading from "../Heading.astro";
import { benefits } from "../../data/site";
---

<Section id="automations" class="overflow-hidden">
  <div class="container relative z-2">
    <Heading
      class="md:max-w-md lg:max-w-2xl"
      title="Workflows that run themselves"
      text="The automations on our own farm — the same ones we bring to every AI adoption engagement."
    />

    <div class="grid gap-6 md:grid-cols-2 md:gap-x-10 md:gap-y-[4.5rem] lg:grid-cols-3 xl:gap-y-[6rem]">
      {
        benefits.map((item) => (
          <div
            class="block relative p-0.5 bg-no-repeat bg-[length:100%_100%] md:max-w-[24rem]"
            style={`background-image: url(${item.backgroundUrl})`}
          >
            <div class="relative z-2 flex flex-col h-[22.625rem] p-[2.375rem] pointer-events-none">
              <h5 class="h5 mb-5">{item.title}</h5>
              <p class="body-2 mb-6 text-n-3">{item.text}</p>
              <div class="flex items-center mt-auto">
                <img src={item.iconUrl} width="48" height="48" alt="" />
                <div class="ml-auto font-code text-xs font-bold text-n-1 uppercase tracking-wider">
                  Always on
                </div>
                <svg class="ml-5 fill-n-1" width="24" height="24">
                  <path d="M8.293 5.293a1 1 0 0 1 1.414 0l6 6a1 1 0 0 1 0 1.414l-6 6a1 1 0 0 1-1.414-1.414L13.586 12 8.293 6.707a1 1 0 0 1 0-1.414z" />
                </svg>
              </div>
            </div>

            {item.light && (
              <div class="absolute top-0 left-1/4 w-full aspect-square bg-radial from-[#28206C] to-[#28206C]/0 to-70% pointer-events-none" />
            )}

            <div class="absolute inset-0.5 bg-n-8" style="clip-path: url(#benefits)">
              <div class="absolute inset-0 opacity-0 transition-opacity hover:opacity-10">
                <img
                  class="w-full h-full object-cover"
                  src={item.imageUrl}
                  width="380"
                  height="362"
                  alt=""
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <svg class="block" width="0" height="0">
      <clipPath id="benefits" clipPathUnits="objectBoundingBox">
        <path
          d="M0.079,0 h0.756 a0.079,0.083,0,0,1,0.058,0.026 l0.086,0.096 A0.079,0.083,0,0,1,1,0.179 V0.917 c0,0.046,-0.035,0.083,-0.079,0.083 H0.079 c-0.044,0,-0.079,-0.037,-0.079,-0.083 V0.083 C0,0.037,0.035,0,0.079,0"
        ></path>
      </clipPath>
    </svg>
  </div>
</Section>
