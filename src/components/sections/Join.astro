---
import Section from "../Section.astro";
import Button from "../Button.astro";
import { site } from "../../data/site";
---

<Section id="contact" crosses>
  <div class="container">
    <div class="relative max-w-[43.125rem] mx-auto py-8 md:py-14 xl:py-0">
      <div class="relative z-1 text-center">
        <h1 class="h1 mb-6">
          Build the unusual with{" "}
          <span class="inline-block relative">
            Rarebit
            <img
              class="absolute top-full left-0 w-full"
              src="/images/curve.png"
              width="624"
              height="28"
              alt=""
            />
          </span>
        </h1>
        <p class="body-1 mb-8 text-n-4">
          Human creativity. Amplified. Tell us which workflow you'd automate first — we'll show
          you what the farm can do with it.
        </p>
        <Button href={`mailto:${site.email}`} white>Get in touch</Button>
      </div>

      <div
        class="absolute top-1/2 left-1/2 w-[46.5rem] h-[46.5rem] border border-n-2/5 rounded-full -translate-x-1/2 -translate-y-1/2 pointer-events-none"
      >
        <div
          class="absolute top-1/2 left-1/2 w-[39.25rem] h-[39.25rem] border border-n-2/10 rounded-full -translate-x-1/2 -translate-y-1/2"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 w-[30.625rem] h-[30.625rem] border border-n-2/10 rounded-full -translate-x-1/2 -translate-y-1/2"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 w-[21.5rem] h-[21.5rem] border border-n-2/10 rounded-full -translate-x-1/2 -translate-y-1/2"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 w-[13.75rem] h-[13.75rem] border border-n-2/10 rounded-full -translate-x-1/2 -translate-y-1/2"
        >
        </div>
      </div>
      <div
        class="absolute top-1/2 left-1/2 w-[46.5rem] h-[46.5rem] border border-n-2/5 rounded-full -translate-x-1/2 -translate-y-1/2 opacity-60 mix-blend-color-dodge pointer-events-none"
      >
        <div class="absolute top-1/2 left-1/2 w-[58.85rem] h-[58.85rem] -translate-x-3/4 -translate-y-1/2">
          <img class="w-full" src="/images/gradient.webp" width="942" height="942" alt="" />
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute -top-[5.75rem] left-[18.5rem] -z-1 w-[19.8125rem] pointer-events-none lg:-top-15 lg:left-[5.5rem]"
  >
    <img class="w-full" src="/images/join/shapes-1.svg" width="317" height="293" alt="" />
  </div>
  <div
    class="absolute right-[15rem] -bottom-[7rem] -z-1 w-[28.1875rem] pointer-events-none lg:right-7 lg:-bottom-[5rem]"
  >
    <img class="w-full" src="/images/join/shapes-2.svg" width="451" height="266" alt="" />
  </div>
</Section>
