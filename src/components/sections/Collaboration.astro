---
import Section from "../Section.astro";
import Button from "../Button.astro";
import { collaboration, site } from "../../data/site";

interface Props {
  /** Home-page teaser: keeps the principle bullets + tool orbit, but the CTA
      points at the standalone /how-we-work page instead of /connect. The full
      page renders its own arc above this section and reuses it without a CTA. */
  teaser?: boolean;
}

const { teaser = false } = Astro.props;

const rotations = [
  "",
  "rotate-[45deg]",
  "rotate-[90deg]",
  "rotate-[135deg]",
  "rotate-[180deg]",
  "rotate-[225deg]",
  "rotate-[270deg]",
  "rotate-[315deg]",
];
const counterRotations = [
  "",
  "-rotate-[45deg]",
  "-rotate-[90deg]",
  "-rotate-[135deg]",
  "-rotate-[180deg]",
  "-rotate-[225deg]",
  "-rotate-[270deg]",
  "-rotate-[315deg]",
];
---

<Section id="how-we-work" crosses>
  <div class="container lg:flex">
    <div class="max-w-[25rem]">
      <h2 class="h2 mb-4 md:mb-8">AI woven into every workflow</h2>
      <ul class="max-w-[22.5rem] mb-10 md:mb-14">
        {
          collaboration.content.map((item) => (
            <li class="mb-3 py-3">
              <div class="flex items-center">
                <img src="/images/rarebit/check.svg" width="24" height="24" alt="" />
                <h6 class="body-2 ml-5">{item.title}</h6>
              </div>
              {item.text && <p class="body-2 mt-3 text-n-4">{item.text}</p>}
            </li>
          ))
        }
      </ul>
      <Button href={teaser ? "/how-we-work" : "/connect"}>
        {teaser ? "How we work" : "Automate with us"}
      </Button>
    </div>

    <div class="mt-15 lg:mt-0 lg:ml-auto xl:w-[37.5rem]">
      <div class="relative lg:w-[22.5rem] lg:mx-auto">
        <p class="body-2 mb-4 text-n-4 md:mb-16 lg:mb-32">{collaboration.text}</p>

        <div
          class="relative left-1/2 flex w-[22.5rem] aspect-square border border-n-6 rounded-full -translate-x-1/2 scale-75 md:scale-100"
        >
          <div class="flex w-60 aspect-square m-auto border border-n-6 rounded-full">
            <div class="w-[5.75rem] aspect-square m-auto p-[0.1875rem] bg-conic-gradient rounded-full">
              <div class="flex items-center justify-center w-full h-full bg-n-8 rounded-full">
                <img src="/images/rarebit/logo.webp" width="48" height="48" alt={site.name} />
              </div>
            </div>
          </div>

          <ul>
            {
              collaboration.apps.map((app, index) => (
                <li
                  class={`absolute top-0 left-1/2 h-1/2 -ml-[1.625rem] ${rotations[index]} origin-bottom`}
                >
                  <div
                    class={`relative -top-[1.625rem] flex w-[3.25rem] h-[3.25rem] bg-n-7 border border-n-1/15 rounded-xl ${counterRotations[index]}`}
                  >
                    <img
                      class="m-auto"
                      src={app.icon}
                      width={app.width}
                      height={app.height}
                      alt={app.title}
                    />
                  </div>
                </li>
              ))
            }
          </ul>

          <div class="hidden absolute top-1/2 right-full w-[32.625rem] -mt-1 mr-10 pointer-events-none xl:block">
            <img src="/images/collaboration/curve-1.svg" width="522" height="182" alt="" />
          </div>
          <div class="hidden absolute top-1/2 left-full w-[10.125rem] -mt-1 ml-10 pointer-events-none xl:block">
            <img src="/images/collaboration/curve-2.svg" width="162" height="76" alt="" />
          </div>
        </div>
      </div>
    </div>
  </div>
</Section>
