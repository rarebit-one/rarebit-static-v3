---
import Section from "../Section.astro";
import Heading from "../Heading.astro";
import Generating from "../Generating.astro";
import { recentMerges, shortDate, farmReplay, FARM_FEED_URL } from "../../lib/farm";

// Receipts: real merges across the org's public repos, fetched at build
// time. Omitted entirely when the API doesn't answer. Five rows so the
// client-side live upgrade (up to 8) doesn't grow the section as sharply.
const merges = await recentMerges(5);

// Client-work replay digest, fetched at build for the no-JS fallback line.
// The client script does the live 24h-delayed replay; this is the summary
// a JS-less visitor (or one whose feed is stale) still sees. Same freshness
// rule as the client: only show the digest if the build-time file's window
// is within the last two days (SGT) — a frozen build must not surface a
// week-old digest as current.
const replay = await farmReplay();
const freshDigest = (() => {
  if (!replay?.window) return null;
  const days = (Date.now() - Date.parse(`${replay.window}T00:00:00+08:00`)) / 86_400_000;
  return days >= 0 && days <= 2 ? replay.digest : null;
})();
---

<Section id="operations">
  <div class="container">
    <Heading
      class="reveal"
      title="The factory is running"
      text="Real automations. Real results. Right now — a look inside the farm."
    />

    {
      /* SSR receipts double as the no-JS fallback; the script upgrades them
         into a live feed of public org activity polled straight from the
         visitor's browser (CORS + ETag — 304s don't count against the
         unauthenticated rate limit). Actors are anonymized to agent/operator;
         only event type, repo, and number are ever rendered. */
      merges && (
        <div class="mb-10" data-farm-feed data-replay-url={FARM_FEED_URL}>
          <div class="flex items-center gap-2 mb-3">
            <span class="hidden w-2 h-2 rounded-full bg-brand-cyan live-dot" data-feed-dot></span>
            <span class="tagline text-n-4" data-feed-label>Receipts · recent merges across the org</span>
          </div>
          <ul class="font-code text-xs leading-6 text-n-3" data-feed-list aria-label="Public activity across the rarebit-one GitHub org">
            {merges.map((merge) => (
              <li class="flex items-baseline gap-3 py-2 border-t border-n-6 last:border-b min-w-0">
                <a
                  class="shrink-0 text-brand-cyan transition-colors hover:text-brand-magenta"
                  href={merge.url}
                  target="_blank"
                  rel="noreferrer"
                >
                  {merge.repo}#{merge.number}
                </a>
                <span class="truncate">{merge.title}</span>
                <span class="ml-auto shrink-0 text-n-4">{shortDate(merge.mergedAt)}</span>
              </li>
            ))}
          </ul>
          {freshDigest && (
            <p class="caption mt-3 text-n-4/70" data-feed-digest>
              Client work · {freshDigest} <span class="text-n-4/50">(replayed on a 24h delay)</span>
            </p>
          )}
        </div>
      )
    }

    <div class="relative">
      {/* Big panel: operator control room with copy on the right */}
      <div
        class="relative z-1 flex items-center h-[38.75rem] mb-5 p-8 border border-n-1/10 rounded-3xl overflow-hidden lg:h-[38.75rem] lg:p-20 xl:h-[45.75rem]"
      >
        <div class="absolute top-0 left-0 w-full h-full pointer-events-none md:w-3/5 xl:w-auto">
          <img
            class="w-full h-full object-cover"
            src="/images/rarebit/operator.webp"
            width="1536"
            height="1024"
            alt="One operator directing the Rarebit automation farm"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-n-8/0 via-n-8/60 to-n-8 md:via-n-8/30"></div>
        </div>

        <div class="relative z-1 max-w-[17rem] ml-auto">
          <h4 class="h4 mb-4">One operator</h4>
          <p class="body-2 mb-[3.125rem] text-n-3">
            The leverage of an agency, without the overhead. Agents work every queue; a human
            signs off on what ships.
          </p>
          <ul class="body-2">
            {
              ["Live operations feed", "Agents on every queue", "Humans approve the merge"].map(
                (item) => (
                  <li class="flex items-start py-4 border-t border-n-6">
                    <img src="/images/rarebit/check.svg" width="24" height="24" alt="" />
                    <p class="ml-4">{item}</p>
                  </li>
                )
              )
            }
          </ul>
        </div>

        <Generating
          label="Workflow evolution · every second"
          class="absolute left-4 right-4 bottom-4 border border-n-1/10 lg:left-1/2 lg:right-auto lg:bottom-8 lg:-translate-x-1/2"
        />
      </div>

      <div class="relative z-1 grid gap-5 lg:grid-cols-2">
        {/* Torii gate art with chat-style instruction */}
        <div class="relative min-h-[38.75rem] border border-n-1/10 rounded-3xl overflow-hidden">
          <div class="absolute inset-0">
            <img
              class="w-full h-full object-cover"
              src="/images/rarebit/torii.webp"
              width="1536"
              height="1024"
              alt="A torii gate under the Rarebit signal — the future is handmade"
            />
          </div>
          <div
            class="absolute inset-0 flex flex-col justify-end p-8 bg-gradient-to-b from-n-8/0 to-n-8/90 lg:p-15"
          >
            <h4 class="h4 mb-4">Direct the farm</h4>
            <p class="body-2 text-n-3">
              Workflows are dispatched in plain language. The farm figures out the rest and
              reports back with receipts.
            </p>
          </div>
          <div
            class="absolute top-8 right-8 max-w-[17.5rem] py-6 px-8 bg-black rounded-t-xl rounded-bl-xl font-code text-base lg:top-16 lg:right-[8.75rem] lg:max-w-[17.5rem]"
          >
            Run the weekly report and draft the client update
            <svg
              class="absolute left-full bottom-0"
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="37"
            >
              <path d="M21.843 37.001c3.564 0 5.348-4.309 2.829-6.828L3.515 9.015A12 12 0 0 1 0 .53v36.471h21.843z"
              ></path>
            </svg>
          </div>
        </div>

        {/* Throughput panel with reply bubble over grid art */}
        <div class="p-4 bg-n-7 rounded-3xl overflow-hidden lg:min-h-[45.75rem]">
          <div class="py-12 px-4 xl:px-8">
            <h4 class="h4 mb-4">Throughput, on tap</h4>
            <p class="body-2 mb-[2.25rem] text-n-3">
              Research, drafts, reviews, deploys — the queue drains itself. What used to take a
              team a week lands before stand-up.
            </p>
            <ul class="flex items-center justify-between">
              {
                [
                  "/images/icons/recording-03.svg",
                  "/images/icons/recording-01.svg",
                  "/images/icons/disc-02.svg",
                  "/images/icons/chrome-cast.svg",
                  "/images/icons/sliders-04.svg",
                ].map((item, index) => (
                  <li
                    class={
                      index === 2
                        ? "flex items-center justify-center w-[3rem] h-[3rem] p-0.25 bg-conic-gradient rounded-2xl md:w-[4.5rem] md:h-[4.5rem]"
                        : "flex items-center justify-center w-10 h-10 bg-n-6 rounded-2xl md:w-15 md:h-15"
                    }
                  >
                    <div
                      class={
                        index === 2
                          ? "flex items-center justify-center w-full h-full bg-n-7 rounded-[0.9375rem]"
                          : "flex items-center justify-center"
                      }
                    >
                      <img src={item} width="24" height="24" alt="" />
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="relative h-[20.5rem] bg-n-8 rounded-xl overflow-hidden md:h-[25rem]">
            <img
              class="w-full h-full object-cover opacity-50"
              src="/images/grid.png"
              width="550"
              height="550"
              alt=""
            />
            <div
              class="absolute top-8 left-[3.125rem] w-full max-w-[14rem] pt-2.5 pr-2.5 pb-7 pl-5 bg-n-6 rounded-t-xl rounded-br-xl font-code text-base md:max-w-[17.5rem]"
            >
              Report generated. Client update drafted for review.
              <div
                class="absolute left-5 -bottom-[1.125rem] flex items-center justify-center w-[2.25rem] h-[2.25rem] bg-color-1 rounded-[0.75rem]"
              >
                <img src="/images/rarebit/logo.webp" width="26" height="26" alt="Rarebit" />
              </div>
              <div class="tagline absolute right-2.5 bottom-1 text-[0.625rem] text-n-3 uppercase">
                just now
              </div>
              <svg
                class="absolute right-full bottom-0 -scale-x-100"
                xmlns="http://www.w3.org/2000/svg"
                width="26"
                height="37"
              >
                <path
                  class="fill-n-6"
                  d="M21.843 37.001c3.564 0 5.348-4.309 2.829-6.828L3.515 9.015A12 12 0 0 1 0 .53v36.471h21.843z"
                ></path>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div
        class="absolute top-0 -left-[10rem] w-[56.625rem] h-[56.625rem] opacity-50 mix-blend-color-dodge pointer-events-none"
      >
        <img
          class="absolute top-1/2 left-1/2 w-[79.5625rem] max-w-[79.5625rem] h-[88.5625rem] -translate-x-1/2 -translate-y-1/2"
          src="/images/gradient.webp"
          width="1417"
          height="1417"
          alt=""
        />
      </div>
    </div>
  </div>
</Section>

<script>
  // Live farm feed — public org events, fetched by the visitor's browser.
  // One request per minute with If-None-Match: 304s are free against the
  // 60/h unauthenticated limit, and polling pauses while the tab is hidden.
  // Anonymization: actors render as agent/operator chips (never usernames),
  // and only event type + repo + number are shown — no titles, no emails.
  const feed = document.querySelector<HTMLElement>("[data-farm-feed]");
  const list = feed?.querySelector<HTMLUListElement>("[data-feed-list]");
  const label = feed?.querySelector<HTMLElement>("[data-feed-label]");
  const dot = feed?.querySelector<HTMLElement>("[data-feed-dot]");

  // `at` is the DISPLAY time: real timestamp for public events, real+24h for
  // replayed client events. `url` is absent on client rows (no link). The
  // chip is agent (bot) / operator (human) for public, client for replay.
  type FeedItem = { id: string; who: "agent" | "operator" | "client"; text: string; url?: string; at: number };

  const EVENTS_URL = "https://api.github.com/orgs/rarebit-one/events?per_page=30";
  const MAX_ROWS = 8;
  let etag = "";
  let items: FeedItem[] = []; // public events
  let replayItems: FeedItem[] = []; // client events already past their +24h reveal
  const seen = new Set<string>();
  let timer = 0;

  const ago = (at: number) => {
    const s = Math.max(0, Math.floor((Date.now() - at) / 1000));
    if (s < 60) return "just now";
    if (s < 3600) return `${Math.floor(s / 60)}m ago`;
    if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
    return `${Math.floor(s / 86400)}d ago`;
  };

  // The public events API returns slim payloads (no html_url, no merged
  // flag, no push sizes) — URLs are constructed from repo + number, and
  // closed PRs say "closed" rather than claiming a merge we can't verify.
  const describe = (event: any): { text: string; url: string } | null => {
    const full: string = String(event.repo?.name ?? "");
    const repo = full.split("/").pop() ?? "";
    const base = `https://github.com/${full}`;
    const p = event.payload ?? {};
    switch (event.type) {
      case "PullRequestEvent": {
        const n = p.number ?? p.pull_request?.number;
        if (!n || (p.action !== "opened" && p.action !== "closed")) return null;
        return { text: `${p.action} ${repo}#${n}`, url: `${base}/pull/${n}` };
      }
      case "PullRequestReviewEvent": {
        const n = p.pull_request?.number;
        return n ? { text: `reviewed ${repo}#${n}`, url: `${base}/pull/${n}` } : null;
      }
      case "IssueCommentEvent": {
        const n = p.issue?.number;
        return n
          ? { text: `commented ${repo}#${n}`, url: p.comment?.html_url ?? `${base}/issues/${n}` }
          : null;
      }
      case "IssuesEvent": {
        const n = p.issue?.number;
        if (!n || (p.action !== "opened" && p.action !== "closed")) return null;
        return { text: `${p.action} issue ${repo}#${n}`, url: `${base}/issues/${n}` };
      }
      case "PushEvent": {
        const branch = String(p.ref ?? "").split("/").pop() ?? "";
        if (!branch) return null;
        return {
          text: `pushed ${branch.slice(0, 28)} → ${repo}`,
          url: `${base}/commits/${branch}`,
        };
      }
      case "ReleaseEvent": {
        const tag = p.release?.tag_name;
        return tag
          ? { text: `released ${tag} · ${repo}`, url: p.release?.html_url ?? `${base}/releases` }
          : null;
      }
      default:
        return null;
    }
  };

  const chipColor = {
    agent: "text-brand-cyan",
    operator: "text-brand-magenta",
    client: "text-color-2",
  } as const;

  const render = () => {
    if (!list) return;
    // Interleave public + revealed client events by display time, newest first.
    const rows = [...items, ...replayItems]
      .sort((a, b) => b.at - a.at)
      .slice(0, MAX_ROWS);

    list.textContent = "";
    for (const item of rows) {
      const li = document.createElement("li");
      li.className = "flex items-baseline gap-3 py-2 border-t border-n-6 last:border-b min-w-0";
      if (!seen.has(item.id)) li.classList.add("feed-enter");

      const chip = document.createElement("span");
      chip.className = `shrink-0 w-[4.5rem] uppercase tracking-wider ${chipColor[item.who]}`;
      chip.textContent = item.who;

      // Public rows link to GitHub; client rows are unlinked (no URL exists).
      const body = item.url ? document.createElement("a") : document.createElement("span");
      body.className = "truncate text-n-3";
      body.textContent = item.text;
      if (item.url && body instanceof HTMLAnchorElement) {
        body.classList.add("transition-colors", "hover:text-n-1");
        body.href = item.url;
        body.target = "_blank";
        body.rel = "noreferrer";
      }

      const time = document.createElement("span");
      time.className = "ml-auto shrink-0 text-n-4";
      // Δ24h marks the replayed (delayed) lane, like a ticker's "delayed" tag.
      time.textContent = item.who === "client" ? `${ago(item.at)} · Δ24h` : ago(item.at);

      li.append(chip, body, time);
      list.append(li);
    }
    // Track only the current window — `seen` exists to gate the entrance
    // animation, not to remember history (it would grow for the tab's life).
    seen.clear();
    rows.forEach((item) => seen.add(item.id));
  };

  // Single poll in flight — the interval and visibilitychange can otherwise
  // race, double-spending the rate budget and double-rendering.
  let inFlight = false;

  const poll = async () => {
    if (inFlight) return;
    inFlight = true;
    try {
      const response = await fetch(EVENTS_URL, {
        headers: {
          Accept: "application/vnd.github+json",
          ...(etag ? { "If-None-Match": etag } : {}),
        },
        cache: "no-store",
      });
      if (response.status === 304) {
        render(); // refresh relative times
        return;
      }
      if (!response.ok) return;
      etag = response.headers.get("ETag") ?? etag;
      const events = await response.json();
      if (!Array.isArray(events)) return;
      const mapped = events
        .map((event): FeedItem | null => {
          const described = describe(event);
          if (!described || !described.url) return null;
          const login: string = event.actor?.login ?? "";
          return {
            id: String(event.id),
            who: login.endsWith("[bot]") ? "agent" : "operator",
            text: described.text,
            url: described.url,
            at: Date.parse(event.created_at ?? "") || Date.now(),
          };
        })
        .filter((item): item is FeedItem => item !== null);
      // The review bots comment constantly — cap comment rows so merges,
      // pushes, and releases stay visible in the window.
      items = [];
      let comments = 0;
      for (const item of mapped) {
        if (item.text.startsWith("commented")) {
          if (comments >= 2) continue;
          comments += 1;
        }
        items.push(item);
        if (items.length >= MAX_ROWS) break;
      }
      if (items.length === 0) return; // keep SSR receipts
      goLive();
      render();
    } catch {
      /* network blocked — the SSR receipts stay */
    } finally {
      inFlight = false;
    }
  };

  let live = false;
  const goLive = () => {
    if (live) return;
    live = true;
    if (label) label.textContent = "Live from the farm · public activity + client lane (replayed · 24h delay)";
    dot?.classList.remove("hidden");
  };

  // --- Client-work replay: yesterday's events, each revealed at at+24h ----
  // The nightly pipeline publishes an anonymized, generic-language replay to
  // Spaces. We reveal each event when its real time + 24h has elapsed, so the
  // lane ticks live without ever showing client activity sooner than a day
  // late. Freshness guard: only replay when the file's window is yesterday
  // (SGT) — never present stale data as "just now".
  const DELAY_MS = 86_400_000;
  type Scheduled = { id: string; text: string; displayAt: number; revealed: boolean };
  let schedule_: Scheduled[] = [];
  const timeouts: number[] = [];

  const yesterdaySgt = () => {
    const sgt = new Date(Date.now() + 8 * 3600_000);
    sgt.setUTCDate(sgt.getUTCDate() - 1);
    return sgt.toISOString().slice(0, 10);
  };

  // Reveal every event now past its +24h mark, (re-)render, and arm a timeout
  // for the next near-future one so it pops in live. Called on load, on each
  // 60s poll tick (so a long-open tab keeps ticking past the first 30 min),
  // and on tab refocus.
  const tickReplay = () => {
    timeouts.forEach(clearTimeout);
    timeouts.length = 0;
    let revealedAny = false;
    let next = Infinity;
    for (const s of schedule_) {
      const wait = s.displayAt - Date.now();
      if (wait <= 0) {
        if (!s.revealed) {
          s.revealed = true;
          replayItems.push({ id: s.id, who: "client", text: s.text, at: s.displayAt });
          revealedAny = true;
        }
      } else {
        next = Math.min(next, wait);
      }
    }
    if (revealedAny) {
      goLive();
      render();
    }
    if (next !== Infinity) {
      timeouts.push(window.setTimeout(tickReplay, Math.min(next, 60_000) + 50));
    }
  };

  const loadReplay = async () => {
    const url = feed?.dataset.replayUrl;
    if (!url) return;
    try {
      const response = await fetch(url, { cache: "no-store" });
      if (!response.ok) return;
      const data = await response.json();
      if (!Array.isArray(data?.events) || data.window !== yesterdaySgt()) return; // stale → digest only
      replayItems = [];
      schedule_ = data.events
        .map((event: any) => {
          const real = Date.parse(event.at);
          return Number.isNaN(real)
            ? null
            : {
                id: `replay-${event.at}`,
                text: String(event.text ?? "").slice(0, 80),
                displayAt: real + DELAY_MS,
                revealed: false,
              };
        })
        .filter(Boolean) as Scheduled[];
      tickReplay();
    } catch {
      /* feed unreachable — SSR digest line stays */
    }
  };

  const schedule = () => {
    clearInterval(timer);
    timer = window.setInterval(() => {
      if (!document.hidden) {
        poll();
        tickReplay(); // keep the lane ticking past the first near-future window
      }
    }, 60_000);
  };

  if (feed && list) {
    poll();
    loadReplay();
    schedule();
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) {
        poll();
        loadReplay();
      }
    });
  }
</script>
