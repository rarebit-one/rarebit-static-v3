---
import Section from "../Section.astro";
import Heading from "../Heading.astro";
import Generating from "../Generating.astro";
import Button from "../Button.astro";
import { recentMerges, shortDate, farmReplay, FARM_FEED_URL } from "../../lib/farm";

interface Props {
  /** Home-page teaser: same receipts + digest + art panels + shared replay
      script, plus a CTA into the standalone /operations live dashboard. The
      dashboard page does not render this component (it lifts the script). */
  teaser?: boolean;
}

const { teaser = false } = Astro.props;

// Receipts: real merges across the org's public repos, fetched at build
// time. Omitted entirely when the API doesn't answer.
const merges = await recentMerges(3);

// Client-work replay digest, fetched at build (SSR). Null until the nightly
// pipeline publishes to the bucket. Freshness guard: only surface the digest
// if the file's window is within the last two days (SGT) — a frozen weekly
// build must not present a stale digest as current. The client script below
// then replays yesterday's events on a fixed 24h delay and refreshes this line.
const replay = await farmReplay();
const freshDigest = (() => {
  if (!replay?.window) return null;
  const days = (Date.now() - Date.parse(`${replay.window}T00:00:00+08:00`)) / 86_400_000;
  return days >= 0 && days <= 2 ? replay.digest : null;
})();
---

<Section id="operations">
  <div class="container">
    <Heading
      title="The factory is running"
      text="Real automations. Real results. Right now — a look inside the farm."
    />

    {
      merges && (
        <div class="mb-10" data-farm-feed data-replay-url={FARM_FEED_URL}>
          <div class="tagline mb-3 text-n-4">Receipts · recent merges across the org</div>
          <ul class="font-code text-xs leading-6 text-n-3" data-feed-list>
            {merges.map((merge) => (
              <li class="flex items-baseline gap-3 py-2 border-t border-n-6 last:border-b min-w-0">
                <a
                  class="shrink-0 text-brand-cyan transition-colors hover:text-brand-magenta"
                  href={merge.url}
                  target="_blank"
                  rel="noreferrer"
                >
                  {merge.repo}#{merge.number}
                </a>
                <span class="truncate">{merge.title}</span>
                <span class="ml-auto shrink-0 text-n-4">{shortDate(merge.mergedAt)}</span>
              </li>
            ))}
          </ul>
          <p class="caption mt-3 text-n-4/70" data-feed-digest hidden={!freshDigest}>
            {freshDigest && (
              <>
                Client work · {freshDigest}{" "}
                <span class="text-n-4/50">(replayed on a 24h delay)</span>
              </>
            )}
          </p>
        </div>
      )
    }

    <div class="relative">
      {/* Big panel: operator control room with copy on the right */}
      <div
        class="relative z-1 flex items-center h-[38.75rem] mb-5 p-8 border border-n-1/10 rounded-3xl overflow-hidden lg:h-[38.75rem] lg:p-20 xl:h-[45.75rem]"
      >
        <div class="absolute top-0 left-0 w-full h-full pointer-events-none md:w-3/5 xl:w-auto">
          <img
            class="w-full h-full object-cover"
            src="/images/rarebit/operator.webp"
            width="1536"
            height="1024"
            loading="lazy"
            decoding="async"
            alt="One operator directing the Rarebit automation farm"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-n-8/0 via-n-8/60 to-n-8 md:via-n-8/30"></div>
        </div>

        <div class="relative z-1 max-w-[17rem] ml-auto">
          <h4 class="h4 mb-4">One operator</h4>
          <p class="body-2 mb-[3.125rem] text-n-3">
            The leverage of an agency, without the overhead. Agents work every queue; a human
            signs off on what ships.
          </p>
          <ul class="body-2">
            {
              ["Live operations feed", "Agents on every queue", "Humans approve the merge"].map(
                (item) => (
                  <li class="flex items-start py-4 border-t border-n-6">
                    <img src="/images/rarebit/check.svg" width="24" height="24" alt="" />
                    <p class="ml-4">{item}</p>
                  </li>
                )
              )
            }
          </ul>
        </div>

        <Generating
          label="Workflow evolution · every second"
          class="absolute left-4 right-4 bottom-4 border border-n-1/10 lg:left-1/2 lg:right-auto lg:bottom-8 lg:-translate-x-1/2"
        />
      </div>

      <div class="relative z-1 grid gap-5 lg:grid-cols-2">
        {/* Torii gate art with chat-style instruction */}
        <div class="relative min-h-[38.75rem] border border-n-1/10 rounded-3xl overflow-hidden">
          <div class="absolute inset-0">
            <img
              class="w-full h-full object-cover"
              src="/images/rarebit/torii.webp"
              width="1536"
              height="1024"
              loading="lazy"
              decoding="async"
              alt="A torii gate under the Rarebit signal — the future is handmade"
            />
          </div>
          <div
            class="absolute inset-0 flex flex-col justify-end p-8 bg-gradient-to-b from-n-8/0 to-n-8/90 lg:p-15"
          >
            <h4 class="h4 mb-4">Direct the farm</h4>
            <p class="body-2 text-n-3">
              Workflows are dispatched in plain language. The farm figures out the rest and
              reports back with receipts.
            </p>
          </div>
          <div
            class="absolute top-8 right-8 max-w-[17.5rem] py-6 px-8 bg-black rounded-t-xl rounded-bl-xl font-code text-base lg:top-16 lg:right-[8.75rem] lg:max-w-[17.5rem]"
          >
            Run the weekly report and draft the client update
            <svg
              class="absolute left-full bottom-0"
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="37"
            >
              <path d="M21.843 37.001c3.564 0 5.348-4.309 2.829-6.828L3.515 9.015A12 12 0 0 1 0 .53v36.471h21.843z"
              ></path>
            </svg>
          </div>
        </div>

        {/* Throughput panel with reply bubble over grid art */}
        <div class="p-4 bg-n-7 rounded-3xl overflow-hidden lg:min-h-[45.75rem]">
          <div class="py-12 px-4 xl:px-8">
            <h4 class="h4 mb-4">Throughput, on tap</h4>
            <p class="body-2 mb-[2.25rem] text-n-3">
              Research, drafts, reviews, deploys — the queue drains itself. What used to take a
              team a week lands before stand-up.
            </p>
            <ul class="flex items-center justify-between">
              {
                [
                  "/images/icons/recording-03.svg",
                  "/images/icons/recording-01.svg",
                  "/images/icons/disc-02.svg",
                  "/images/icons/chrome-cast.svg",
                  "/images/icons/sliders-04.svg",
                ].map((item, index) => (
                  <li
                    class={
                      index === 2
                        ? "flex items-center justify-center w-[3rem] h-[3rem] p-0.25 bg-conic-gradient rounded-2xl md:w-[4.5rem] md:h-[4.5rem]"
                        : "flex items-center justify-center w-10 h-10 bg-n-6 rounded-2xl md:w-15 md:h-15"
                    }
                  >
                    <div
                      class={
                        index === 2
                          ? "flex items-center justify-center w-full h-full bg-n-7 rounded-[0.9375rem]"
                          : "flex items-center justify-center"
                      }
                    >
                      <img src={item} width="24" height="24" alt="" />
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="relative h-[20.5rem] bg-n-8 rounded-xl overflow-hidden md:h-[25rem]">
            <img
              class="w-full h-full object-cover opacity-50"
              src="/images/grid.png"
              width="550"
              height="550"
              alt=""
            />
            <div
              class="absolute top-8 left-[3.125rem] w-full max-w-[14rem] pt-2.5 pr-2.5 pb-7 pl-5 bg-n-6 rounded-t-xl rounded-br-xl font-code text-base md:max-w-[17.5rem]"
            >
              Report generated. Client update drafted for review.
              <div
                class="absolute left-5 -bottom-[1.125rem] flex items-center justify-center w-[2.25rem] h-[2.25rem] bg-color-1 rounded-[0.75rem]"
              >
                <img src="/images/rarebit/logo.webp" width="26" height="26" alt="Rarebit" />
              </div>
              <div class="tagline absolute right-2.5 bottom-1 text-[0.625rem] text-n-3 uppercase">
                just now
              </div>
              <svg
                class="absolute right-full bottom-0 -scale-x-100"
                xmlns="http://www.w3.org/2000/svg"
                width="26"
                height="37"
              >
                <path
                  class="fill-n-6"
                  d="M21.843 37.001c3.564 0 5.348-4.309 2.829-6.828L3.515 9.015A12 12 0 0 1 0 .53v36.471h21.843z"
                ></path>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div
        class="absolute top-0 -left-[10rem] w-[56.625rem] h-[56.625rem] opacity-50 mix-blend-color-dodge pointer-events-none"
      >
        <img
          class="absolute top-1/2 left-1/2 w-[79.5625rem] max-w-[79.5625rem] h-[88.5625rem] -translate-x-1/2 -translate-y-1/2"
          src="/images/gradient.webp"
          width="1417"
          height="1417"
          loading="lazy"
          decoding="async"
          alt=""
        />
      </div>
    </div>

    {
      teaser && (
        <div class="relative z-1 flex justify-center mt-12 md:mt-15 xl:mt-20">
          <Button href="/operations">See the live dashboard</Button>
        </div>
      )
    }
  </div>
</Section>

<script>
  // Client-work replay lane. Reads the nightly-published artifact and reveals
  // each event into the receipts list on a fixed real-time + 24h delay — a
  // delayed ticker. No-ops silently until the bucket has data (404 → return),
  // so the SSR receipts + digest stand on their own. Replay-only: no live
  // GitHub feed. The published text is already validator-gated; rows are still
  // built with textContent (never innerHTML) as defence in depth.
  const feed = document.querySelector<HTMLElement>("[data-farm-feed]");
  const list = feed?.querySelector<HTMLUListElement>("[data-feed-list]");
  const digestEl = feed?.querySelector<HTMLElement>("[data-feed-digest]");
  const DELAY_MS = 24 * 60 * 60 * 1000;

  type Scheduled = { id: string; text: string; displayAt: number; revealed: boolean };

  // Yesterday's date in SGT (UTC+8) as YYYY-MM-DD — the window the pipeline
  // labels its artifact with. Shift now into SGT wall-clock, step back a day.
  const yesterdaySgt = () => {
    const sgt = new Date(Date.now() + 8 * 3_600_000);
    sgt.setUTCDate(sgt.getUTCDate() - 1);
    return sgt.toISOString().slice(0, 10);
  };

  // The build-frozen digest may be days old (weekly rebuild), so the client
  // owns this line at runtime: refresh from a fresh artifact, hide otherwise —
  // never leave a stale line labelled "24h delay".
  const setDigest = (text: string | null) => {
    if (!digestEl) return;
    if (!text) {
      digestEl.hidden = true;
      return;
    }
    digestEl.textContent = `Client work · ${text} `;
    const note = document.createElement("span");
    note.className = "text-n-4/50";
    note.textContent = "(replayed on a 24h delay)";
    digestEl.appendChild(note);
    digestEl.hidden = false;
  };

  let schedule: Scheduled[] = [];
  const seen = new Set<string>();
  let timer = 0;

  const revealRow = (item: Scheduled) => {
    if (!list || seen.has(item.id)) return;
    seen.add(item.id);
    const li = document.createElement("li");
    li.className =
      "flex items-baseline gap-3 py-2 border-t border-n-6 last:border-b min-w-0";
    const tag = document.createElement("span");
    tag.className = "shrink-0 text-n-4/70";
    tag.textContent = "Δ24h";
    const txt = document.createElement("span");
    txt.className = "truncate text-n-3";
    txt.textContent = item.text;
    const who = document.createElement("span");
    who.className = "ml-auto shrink-0 text-n-4";
    who.textContent = "client";
    li.append(tag, txt, who);
    list.prepend(li);
  };

  const tick = () => {
    const now = Date.now();
    let next = Infinity;
    for (const s of schedule) {
      if (s.revealed) continue;
      const wait = s.displayAt - now;
      if (wait <= 0) {
        s.revealed = true;
        revealRow(s);
      } else {
        next = Math.min(next, wait);
      }
    }
    if (next !== Infinity) {
      clearTimeout(timer);
      // Cap the wait so a far-future event still re-checks at least hourly.
      timer = window.setTimeout(tick, Math.min(next, 3_600_000) + 50);
    }
  };

  const load = async () => {
    const url = feed?.dataset.replayUrl;
    if (!url) return;
    try {
      const response = await fetch(url, { cache: "no-store" });
      if (!response.ok) return;
      const data = await response.json();
      // Stale or malformed → hide the build-frozen digest, reveal nothing.
      // NB: the client is intentionally STRICTER than the SSR freshDigest
      // guard (which accepts a 2-day window so a weekly build still shows
      // something). The client is authoritative at runtime: it only replays
      // *yesterday's* artifact and suppresses any older digest the SSR
      // optimistically rendered. Don't "harmonize" the two thresholds.
      if (!Array.isArray(data?.events) || data.window !== yesterdaySgt()) {
        setDigest(null);
        return;
      }
      setDigest(typeof data.digest === "string" ? data.digest : null);
      schedule = data.events
        .map((event: { at?: string; text?: string }, index: number) => {
          const real = Date.parse(String(event.at));
          return Number.isNaN(real)
            ? null
            : {
                // Index-scoped so events sharing an `at` second don't collide.
                id: `replay-${index}-${event.at}`,
                text: String(event.text ?? "").slice(0, 80),
                displayAt: real + DELAY_MS,
                revealed: false,
              };
        })
        .filter(Boolean) as Scheduled[];
      tick();
    } catch {
      /* feed unreachable — SSR receipts + digest stand */
    }
  };

  if (feed && list) {
    load();
    // Re-sync when the tab returns to the foreground (a long-open tab crosses
    // new reveal windows; a new day's artifact may have published).
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) load();
    });
  }
</script>
