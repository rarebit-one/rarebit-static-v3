---
import Section from "../Section.astro";
import Tagline from "../Tagline.astro";
import Heading from "../Heading.astro";
import Button from "../Button.astro";
import { roadmap, site } from "../../data/site";
---

<Section id="roadmap" class="overflow-hidden">
  <div class="container md:pb-10">
    <Heading tag="The farm keeps growing" title="What we're building" />

    <div class="relative grid gap-6 md:grid-cols-2 md:gap-4 md:pb-[7rem]">
      {
        roadmap.map((item, index) => (
          <div
            class={`md:flex ${index % 2 !== 0 ? "md:translate-y-[7rem]" : ""} p-0.25 rounded-[2.5rem] ${
              item.colorful ? "bg-conic-gradient" : "bg-n-6"
            }`}
          >
            <div class="relative p-8 bg-n-8 rounded-[2.4375rem] overflow-hidden xl:p-15">
              <div class="absolute top-0 left-0 max-w-full">
                <img class="w-full" src="/images/grid.png" width="550" height="550" alt="" />
              </div>
              <div class="relative z-1">
                <div class="flex items-center justify-between max-w-[27rem] mb-8 md:mb-20">
                  <Tagline>{item.date}</Tagline>
                  <div class="flex items-center px-4 py-1 bg-n-1 rounded text-n-8">
                    <img
                      class="mr-2.5"
                      src={
                        item.status === "done"
                          ? "/images/icons/check.svg"
                          : "/images/icons/loading-01.svg"
                      }
                      width="16"
                      height="16"
                      alt=""
                    />
                    <div class="tagline">{item.status === "done" ? "Live" : "In progress"}</div>
                  </div>
                </div>
                <div class="mb-8 md:mb-20">
                  <div class="-my-10 -mx-15">
                    <img class="w-full" src={item.imageUrl} width="628" height="426" alt="" />
                  </div>
                </div>
                <h4 class="h4 mb-4">{item.title}</h4>
                <p class="body-2 text-n-4">{item.text}</p>
              </div>
            </div>
          </div>
        ))
      }

      <div
        class="absolute top-[18.25rem] -left-[30.375rem] w-[56.625rem] opacity-60 mix-blend-color-dodge pointer-events-none"
      >
        <div class="absolute top-1/2 left-1/2 w-[58.85rem] h-[58.85rem] -translate-x-3/4 -translate-y-1/2">
          <img class="w-full" src="/images/gradient.webp" width="942" height="942" alt="" />
        </div>
      </div>
    </div>

    <div class="flex justify-center mt-12 md:mt-15 xl:mt-20">
      <Button href={site.github}>Our open source</Button>
    </div>
  </div>
</Section>
