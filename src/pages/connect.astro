---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Heading from "../components/Heading.astro";
import Tagline from "../components/Tagline.astro";
import Button from "../components/Button.astro";
import { site } from "../data/site";
import QRCode from "qrcode";

const endpoint = site.mcpEndpoint;

// Desktop → phone handoff: connectors must be added on web/desktop, but the
// form works anywhere — the QR opens this page on the phone. Build-time SVG,
// no client JS.
const qrSvg = await QRCode.toString(`https://${site.domain}/connect`, {
  type: "svg",
  margin: 0,
  color: { dark: "#cac6dd", light: "#0000" },
});

const clients = [
  {
    id: "claude-code",
    title: "Claude Code",
    instructions: "One command in your terminal:",
    snippet: `claude mcp add --transport http rarebit ${endpoint}`,
  },
  {
    id: "claude",
    title: "Claude (web & desktop)",
    instructions:
      "Settings → Connectors → Add custom connector, then paste the endpoint:",
    snippet: endpoint,
  },
  {
    id: "cursor",
    title: "Cursor",
    instructions: "Add to .cursor/mcp.json:",
    snippet: `{
  "mcpServers": {
    "rarebit": { "url": "${endpoint}" }
  }
}`,
  },
  {
    id: "chatgpt",
    title: "ChatGPT",
    instructions:
      "Settings → Apps & Connectors (developer mode) → Create, then paste the endpoint:",
    snippet: endpoint,
  },
  {
    id: "generic",
    title: "Anything else",
    instructions:
      "Any MCP client that speaks Streamable HTTP can connect with this config:",
    snippet: `{
  "mcpServers": {
    "rarebit": {
      "type": "http",
      "url": "${endpoint}"
    }
  }
}`,
  },
];

const tools = [
  {
    name: "how_we_work",
    text: "How the automation farm operates — engagement model, human-in-the-loop, what we automate.",
  },
  {
    name: "open_source",
    text: "The open-source catalog: every library we publish, with what it's for.",
  },
  {
    name: "intake_questionnaire",
    text: "A short, structured intake your assistant walks you through to scope the right kind of help.",
  },
  {
    name: "submit_inquiry",
    text: "Sends the scoped request to us. We read every one and reply by email.",
  },
];
---

<Layout
  title="Connect — Rarebit"
  description="Connect your AI assistant to Rarebit over MCP — ask how we work, scope your automation, and get in touch without leaving your chat. On mobile? Use the form."
>
  <Section crosses>
    <div class="container">
      <Heading
        tag="Model Context Protocol"
        title="Bring your own AI"
        text="Add our MCP server to the assistant you already use — ask it how we work, let it scope what you need, and send the inquiry without leaving the chat. On your phone? Assistants only let you add connectors on web or desktop — the form below reaches the same inbox."
      />

      <div class="max-w-[50rem] mx-auto mb-15">
        <div class="relative p-0.5 rounded-2xl bg-conic-gradient">
          <div class="flex items-center justify-between gap-4 px-4 py-4 bg-n-8 rounded-[0.875rem] flex-wrap md:px-6 md:py-5">
            <div class="min-w-0">
              <div class="tagline mb-1 text-n-4">MCP endpoint · Streamable HTTP</div>
              <code class="font-code text-sm text-brand-cyan break-all md:text-base">{endpoint}</code>
            </div>
            <button
              class="button px-4 py-2 border border-n-1/15 rounded-lg text-n-1 cursor-pointer transition-colors hover:text-brand-magenta hover:border-brand-magenta/40"
              data-copy={endpoint}
            >
              Copy
            </button>
          </div>
        </div>
      </div>

      {/* Live demo — the endpoint answering from this very page */}
      <div class="max-w-[50rem] mx-auto mb-15">
        <div class="flex flex-col min-w-0 p-5 border border-n-1/10 rounded-3xl bg-n-7 md:p-8">
          <Tagline class="mb-4">Try it from right here</Tagline>
          <p class="body-2 mb-6 text-n-4">
            These buttons send the live endpoint the same JSON-RPC your assistant would. No
            signup, no key — it just answers.
          </p>
          <div class="flex flex-wrap gap-3">
            {
              ["how_we_work", "open_source", "intake_questionnaire"].map((tool) => (
                <button
                  class="button px-4 py-2 border border-n-1/15 rounded-lg font-code normal-case text-n-1 cursor-pointer transition-colors hover:text-brand-magenta hover:border-brand-magenta/40"
                  data-demo-tool={tool}
                >
                  {tool}
                </button>
              ))
            }
          </div>
          <pre
            class="hidden mt-6 p-4 bg-n-8 rounded-xl font-code text-xs leading-5 text-n-2 whitespace-pre-wrap max-h-80 overflow-y-auto md:text-sm md:leading-6"
            data-demo-output
            data-endpoint={endpoint}
            aria-live="polite"
          ></pre>
        </div>
      </div>

      <div class="grid gap-5 lg:grid-cols-2 mb-15">
        {
          clients.map((client) => (
            <div class="flex flex-col min-w-0 p-5 border border-n-1/10 rounded-3xl bg-n-7 transition-colors hover:border-brand-cyan/30 md:p-8">
              <h5 class="h6 mb-2">{client.title}</h5>
              <p class="body-2 mb-4 text-n-4">{client.instructions}</p>
              <div class="relative mt-auto">
                <pre class="p-4 pr-14 bg-n-8 rounded-xl font-code text-xs leading-5 text-n-2 overflow-x-auto md:text-sm md:leading-6"><code>{client.snippet}</code></pre>
                <button
                  class="button absolute top-3 right-3 px-2 py-1 text-n-4 cursor-pointer transition-colors hover:text-brand-magenta"
                  data-copy={client.snippet}
                  aria-label={`Copy ${client.title} setup`}
                >
                  Copy
                </button>
              </div>
            </div>
          ))
        }

        <div class="flex flex-col min-w-0 p-5 border border-n-1/10 rounded-3xl bg-n-7 md:p-8">
          <Tagline class="mb-4">What your assistant gets</Tagline>
          <ul class="body-2">
            {
              tools.map((tool) => (
                <li class="py-3 border-t border-n-6 first:border-t-0">
                  <code class="font-code text-sm text-brand-cyan">{tool.name}</code>
                  <p class="mt-1 text-n-4">{tool.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      {/* Form fallback — same GitHub-issue inbox as submit_inquiry, via the
          /inquiry function, for anyone who can't add an MCP connector. */}
      <div class="max-w-[50rem] mx-auto mb-15" id="inquiry">
        <div class="flex flex-col min-w-0 p-5 border border-n-1/10 rounded-3xl bg-n-7 md:p-8">
          <div class="flex items-start justify-between gap-6 mb-6">
            <div>
              <Tagline class="mb-4">No MCP? Same inbox</Tagline>
              <p class="body-2 text-n-4">
                On mobile, or just prefer typing it yourself? This lands exactly where the MCP
                inquiries do — we read every one and reply by email.
              </p>
            </div>
            <div class="hidden shrink-0 text-center md:block" aria-hidden="true">
              <div class="w-24 h-24 [&>svg]:w-full [&>svg]:h-full" set:html={qrSvg} />
              <div class="tagline mt-2 text-n-4/70">Open on phone</div>
            </div>
          </div>

          <form data-inquiry-form novalidate>
            <div class="grid gap-4 sm:grid-cols-2 mb-4">
              <label class="block">
                <span class="tagline block mb-2 text-n-4">Name</span>
                <input
                  class="w-full px-4 py-3 bg-n-8 border border-n-1/10 rounded-xl text-n-1 placeholder:text-n-4/50 transition-colors focus:outline-none focus:border-brand-cyan/60"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                />
              </label>
              <label class="block">
                <span class="tagline block mb-2 text-n-4">Email</span>
                <input
                  class="w-full px-4 py-3 bg-n-8 border border-n-1/10 rounded-xl text-n-1 placeholder:text-n-4/50 transition-colors focus:outline-none focus:border-brand-cyan/60"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                />
              </label>
            </div>
            <label class="block mb-4">
              <span class="tagline block mb-2 text-n-4">Company <span class="normal-case">(optional)</span></span>
              <input
                class="w-full px-4 py-3 bg-n-8 border border-n-1/10 rounded-xl text-n-1 placeholder:text-n-4/50 transition-colors focus:outline-none focus:border-brand-cyan/60"
                type="text"
                name="company"
                autocomplete="organization"
              />
            </label>
            <label class="block mb-6">
              <span class="tagline block mb-2 text-n-4">What would you automate?</span>
              <textarea
                class="w-full px-4 py-3 bg-n-8 border border-n-1/10 rounded-xl text-n-1 placeholder:text-n-4/50 transition-colors focus:outline-none focus:border-brand-cyan/60 min-h-32 resize-y"
                name="message"
                required
                placeholder="The workflow, what makes it painful, and the tools it runs through today."></textarea>
            </label>

            {/* Honeypot — humans never see or fill this */}
            <div class="hidden" aria-hidden="true">
              <label>
                Website
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>
            </div>

            <div class="flex flex-wrap items-center gap-4">
              <Button data-inquiry-submit>Send inquiry</Button>
              <p class="body-2 text-n-4" data-inquiry-status aria-live="polite"></p>
            </div>
          </form>

          <p class="body-2 hidden text-n-2" data-inquiry-success role="status">
            Inquiry received — thank you! We read every submission and will reply by email
            within two working days.
          </p>

          <p class="caption mt-6 text-n-4/70">
            No cookies, no trackers. Your message lands in a private repo and is only used to
            reply to you — <a class="transition-colors hover:text-n-1" href="/privacy">privacy</a>.
          </p>
        </div>
      </div>

      <p class="body-2 text-center text-n-4">
        Prefer plain email? <a class="text-n-1 transition-colors hover:text-brand-magenta" href={`mailto:${site.email}`}>{site.email}</a>
      </p>
    </div>
  </Section>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-inquiry-form]");
  const submit = form?.querySelector<HTMLButtonElement>("[data-inquiry-submit]");
  const status = form?.querySelector<HTMLElement>("[data-inquiry-status]");
  const success = document.querySelector<HTMLElement>("[data-inquiry-success]");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;
    if (!status || !submit) return;

    const label = submit.querySelector("span");
    const idle = label?.textContent ?? "";
    submit.disabled = true;
    if (label) label.textContent = "Sending…";
    status.textContent = "";

    try {
      const response = await fetch("/inquiry", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ...Object.fromEntries(new FormData(form)),
          // Speed-gate input: ms since page render (see inquiry/index.mjs).
          elapsed: Math.round(performance.now()),
        }),
      });
      const payload = await response.json().catch(() => ({}));
      if (response.ok && payload.ok) {
        form.classList.add("hidden");
        success?.classList.remove("hidden");
        return;
      }
      status.textContent =
        payload.error ?? "Something went wrong — please email us instead.";
    } catch {
      status.textContent =
        "Could not reach the inbox — please email us instead.";
    } finally {
      submit.disabled = false;
      if (label) label.textContent = idle;
    }
  });

  // Live MCP demo — same JSON-RPC envelope an assistant sends.
  const demoOutput = document.querySelector<HTMLPreElement>("[data-demo-output]");
  let demoId = 0;
  document.querySelectorAll<HTMLButtonElement>("[data-demo-tool]").forEach((button) => {
    button.addEventListener("click", async () => {
      if (!demoOutput) return;
      demoOutput.classList.remove("hidden");
      demoOutput.textContent = `→ tools/call ${button.dataset.demoTool}…`;
      try {
        const response = await fetch(demoOutput.dataset.endpoint ?? "", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({
            jsonrpc: "2.0",
            id: ++demoId,
            method: "tools/call",
            params: { name: button.dataset.demoTool, arguments: {} },
          }),
        });
        const payload = await response.json();
        demoOutput.textContent =
          payload.result?.content?.[0]?.text ?? JSON.stringify(payload.error ?? payload, null, 2);
      } catch {
        demoOutput.textContent =
          "Could not reach the endpoint from this network — try it from your assistant instead.";
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((button) => {
    button.addEventListener("click", async () => {
      const text = button.dataset.copy ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const label = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          button.textContent = label;
        }, 1500);
      } catch {
        /* clipboard unavailable — leave the text selectable */
      }
    });
  });
</script>
