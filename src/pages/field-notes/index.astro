---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Heading from "../../components/Heading.astro";

const notes = (await getCollection("fieldNotes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-SG", {
    day: "numeric", month: "short", year: "numeric",
    hour: "2-digit", minute: "2-digit", timeZone: "Asia/Singapore",
  }).format(date);
---

<Layout
  title="Field notes — Rarebit"
  description="Build logs from the automation farm: what we shipped, what broke, and what we learned — agent-drafted, human-reviewed."
>
  <Section crosses>
    <div class="container">
      <Heading
        tag="Build logs from the farm"
        title="Field notes"
        text="What we shipped, what broke, and what we learned. Agent-drafted, human-reviewed — like everything else here."
      />

      <div class="max-w-[50rem] mx-auto">
        <ul>
          {
            notes.map((note) => (
              <li class="reveal border-t border-n-6 last:border-b">
                <a class="group block py-8" href={`/field-notes/${note.id}/`}>
                  <div class="tagline mb-3 text-n-4">{formatDate(note.data.pubDate)}</div>
                  <h3 class="h5 mb-3 transition-colors group-hover:text-brand-magenta">
                    {note.data.title}
                  </h3>
                  <p class="body-2 text-n-4">{note.data.description}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>
</Layout>
