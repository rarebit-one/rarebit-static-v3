---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Heading from "../components/Heading.astro";
import Tagline from "../components/Tagline.astro";
import Button from "../components/Button.astro";
import HeroBanner from "../components/HeroBanner.astro";
import { openSourceCatalog } from "../data/openSource";
import { site } from "../data/site";
import { gemInfo, compactNumber } from "../lib/farm";

// Presentational only (kept out of the catalog data so the MCP sync stays
// clean): a brand shot + one-line frame for each category's alternating row.
const categoryMeta: Record<string, { image: string; alt: string; blurb: string }> = {
  auth: {
    image: "/images/rarebit/operator.webp",
    alt: "An operator at the controls",
    blurb:
      "The login box is the easy part. These carry the parts that aren't — OAuth 2.0 / OIDC, passwordless OTP, and national digital identity — secure by default, built on Rails' own primitives.",
  },
  reliability: {
    image: "/images/rarebit/dashboard-factory.webp",
    alt: "The farm's live operations dashboard",
    blurb:
      "What keeps the farm honest: circuit breakers, drop-in health checks, and database-backed audit trails that turn 'is it up?' into something you can actually answer.",
  },
  data: {
    image: "/images/rarebit/torii.webp",
    alt: "A gateway at dusk",
    blurb:
      "Data patterns that stay trustworthy long after the write — immutable journal entries with declarative aggregate projections, no bespoke reconciliation.",
  },
};

// Live version + download counts from RubyGems at build time; the static
// version string is the fallback when the API doesn't answer.
const catalog = await Promise.all(
  openSourceCatalog.map(async (category) => ({
    ...category,
    repos: await Promise.all(
      category.repos.map(async (repo) => {
        const live = await gemInfo(repo.repo);
        return {
          ...repo,
          version: live ? `v${live.version}` : repo.version,
          downloads: live?.downloads ?? null,
        };
      })
    ),
  }))
);

const softwareLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Rarebit open-source Ruby gems",
  itemListElement: catalog
    .flatMap((category) => category.repos)
    .map((repo, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "SoftwareSourceCode",
        name: repo.name,
        description: repo.description,
        codeRepository: `https://github.com/rarebit-one/${repo.repo}`,
        programmingLanguage: "Ruby",
        version: repo.version.replace(/^v/, ""),
      },
    })),
};
---

<Layout
  title="Open source — Rarebit"
  description="The primitives the Rarebit automation farm runs on — auth, audit, ledger, health, and circuit-breaker building blocks — are open source. Use them."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
  <Section crosses>
    <div class="container">
      <Heading
        level={1}
        tag="The future is handmade"
        title="Open-source primitives"
        text="The building blocks we run on — auth, reliability, and data patterns extracted from real production Rails work, released as focused Ruby gems. No frameworks, no lock-in."
      />

      {
        catalog.map((category, i) => (
          <div class="mb-20 last:mb-0">
            {/* Alternating image row — the FeaturesPage layout, per category. */}
            <div
              class={`reveal mb-10 flex flex-col items-center gap-8 lg:mb-14 lg:gap-14 ${
                i % 2 === 1 ? "lg:flex-row-reverse" : "lg:flex-row"
              }`}
            >
              <div class="w-full lg:w-1/2">
                <HeroBanner
                  src={categoryMeta[category.id].image}
                  alt={categoryMeta[category.id].alt}
                  aspect="aspect-[16/10]"
                  width={600}
                  height={400}
                />
              </div>
              <div class="w-full lg:w-1/2">
                <Tagline class="mb-4">{category.mcpLabel}</Tagline>
                <h2 class="h3 mb-4">{category.title}</h2>
                <p class="body-2 text-n-3">{categoryMeta[category.id].blurb}</p>
              </div>
            </div>
            <div class="grid gap-5 lg:grid-cols-2">
              {category.repos.map((repo) => (
                <div class="reveal relative flex flex-col p-6 border border-n-1/10 rounded-3xl bg-n-7 overflow-hidden transition-colors hover:border-brand-cyan/30 md:p-8 xl:p-10">
                  <div class="absolute top-0 left-0 max-w-full opacity-40 pointer-events-none">
                    <img class="w-full" src="/images/grid.png" width="550" height="550" alt="" />
                  </div>
                  <div class="relative z-1 flex flex-col h-full">
                    <div class="flex items-center justify-between mb-4">
                      <Tagline>{repo.kind}</Tagline>
                      <div class="tagline text-n-4">
                        {repo.version}
                        {repo.downloads ? ` · ${compactNumber(repo.downloads)} downloads` : ""}
                      </div>
                    </div>
                    <h5 class="h6 mb-2">{repo.name}</h5>
                    <p class="body-2 mb-4 text-n-2">{repo.description}</p>
                    <p class="body-2 mb-6 text-n-4">{repo.body}</p>
                    {repo.bullets && (
                      <ul class="body-2 mb-6">
                        {repo.bullets.map((bullet) => (
                          <li class="flex items-start py-2 border-t border-n-6">
                            <img src="/images/rarebit/check.svg" width="20" height="20" alt="" />
                            <p class="ml-3 text-n-3">{bullet}</p>
                          </li>
                        ))}
                      </ul>
                    )}
                    <div class="flex items-center justify-between gap-3 mt-auto mb-4 px-4 py-2.5 bg-n-8 rounded-xl min-w-0">
                      <code class="font-code text-xs text-n-3 truncate">gem install {repo.repo}</code>
                      <button
                        class="button shrink-0 text-n-4 cursor-pointer transition-colors hover:text-brand-magenta"
                        data-copy={`gem install ${repo.repo}`}
                        aria-label={`Copy install command for ${repo.name}`}
                      >
                        Copy
                      </button>
                    </div>
                    <a
                      class="button inline-flex items-center text-n-1 transition-colors hover:text-brand-magenta"
                      href={`https://github.com/rarebit-one/${repo.repo}`}
                      target="_blank"
                      rel="noreferrer"
                    >
                      View on GitHub
                      <svg class="ml-3 fill-current" width="16" height="16" viewBox="0 0 24 24">
                        <path d="M8.293 5.293a1 1 0 0 1 1.414 0l6 6a1 1 0 0 1 0 1.414l-6 6a1 1 0 0 1-1.414-1.414L13.586 12 8.293 6.707a1 1 0 0 1 0-1.414z" />
                      </svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }

      <div class="flex justify-center mt-15">
        <Button href={site.github}>Everything on GitHub</Button>
      </div>
    </div>
  </Section>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((button) => {
    button.addEventListener("click", async () => {
      const text = button.dataset.copy ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const label = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          button.textContent = label;
        }, 1500);
      } catch {
        /* clipboard unavailable — leave the text selectable */
      }
    });
  });
</script>
